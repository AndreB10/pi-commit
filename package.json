{
  "name": "@andre-barbosa/pi-commit",
  "version": "0.1.2",
  "description": "A read-only pi extension that suggests Conventional Commit messages for uncommitted changes",
  "type": "module",
  "license": "MIT",
  "author": "Andre Barbosa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndreB10/pi-commit.git"
  },
  "homepage": "https://github.com/AndreB10/pi-commit#readme",
  "bugs": {
    "url": "https://github.com/AndreB10/pi-commit/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "git",
    "conventional-commits"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.81.1",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@earendil-works/pi-tui": "0.81.1",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
